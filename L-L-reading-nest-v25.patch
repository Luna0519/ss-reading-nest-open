+import { fireEvent, render, screen } from "@testing-library/react";
+import { describe, expect, it, vi } from "vitest";
+import type { CompanionComment, ReadingDiscussionDetail } from "@ss/shared";
+import { DiscussionDrawer } from "./DiscussionDrawer.js";
+import { ReadingDiscussionCard } from "./ReadingDiscussionCard.js";
+
+const anchor: CompanionComment = {
+  id: "comment-1",
+  sessionId: "session-1",
+  position: { kind: "paragraph", index: 12, total: 49, label: "第 12 段" },
+  mode: "light_chat",
+  length: "normal",
+  text: "今天一路读到这里，真正反复追问的是自己的真理。",
+  source: "current_context",
+  inRecent: true,
+  inHistory: true,
+  createdAt: "2026-07-18T00:00:00.000Z"
+};
+
+const detail: ReadingDiscussionDetail = {
+  discussion: {
+    id: "discussion-1",
+    sessionId: "session-1",
+    position: anchor.position,
+    anchorCommentId: anchor.id,
+    anchorText: anchor.text,
+    mood: "resonance",
+    status: "open",
+    currentRound: 1,
+    createdAt: "2026-07-18T00:00:00.000Z",
+    updatedAt: "2026-07-18T00:02:00.000Z"
+  },
+  messages: [
+    {
+      id: "message-1",
+      discussionId: "discussion-1",
+      sequence: 1,
+      roundNumber: 1,
+      role: "assistant",
+      kind: "anchor",
+      text: anchor.text,
+      operationId: "anchor-1",
+      createdAt: "2026-07-18T00:00:00.000Z"
+    },
+    {
+      id: "message-2",
+      discussionId: "discussion-1",
+      sequence: 2,
+      roundNumber: 1,
+      role: "user",
+      kind: "message",
+      text: "我也觉得这句话很有共鸣。".repeat(20),
+      operationId: "user-1",
+      createdAt: "2026-07-18T00:01:00.000Z"
+    }
+  ]
+};
+
+describe("ReadingDiscussionCard", () => {
+  it("toggles one compact mood and opens the complete discussion", () => {
+    const onMood = vi.fn();
+    const onReply = vi.fn();
+    render(
+      <ReadingDiscussionCard
+        anchor={anchor}
+        summary={{ discussion: detail.discussion, messageCount: 2, lastMessageAt: detail.discussion.updatedAt }}
+        onMood={onMood}
+        onReply={onReply}
+      />
+    );
+
+    expect(screen.getByText(anchor.text)).toBeInTheDocument();
+    expect(screen.getByRole("button", { name: /共鸣/ })).toHaveAttribute("aria-pressed", "true");
+    fireEvent.click(screen.getByRole("button", { name: /共鸣/ }));
+    expect(onMood).toHaveBeenCalledWith(anchor, null);
+    fireEvent.click(screen.getByRole("button", { name: /没看懂/ }));
+    expect(onMood).toHaveBeenCalledWith(anchor, "confused");
+    fireEvent.click(screen.getByRole("button", { name: "回复哥哥" }));
+    expect(onReply).toHaveBeenCalledWith(anchor);
+  });
+});
+
+describe("DiscussionDrawer", () => {
+  it("renders long ordered messages in one drawer and sends without a manual save step", () => {
+    const onSend = vi.fn();
+    const onCloseRound = vi.fn();
+    const { container } = render(
+      <DiscussionDrawer
+        bookTitle="悉达多"
+        detail={detail}
+        awaitingReply
+        onSend={onSend}
+        onCloseRound={onCloseRound}
+        onClose={vi.fn()}
+      />
+    );
+
+    expect(container.querySelectorAll(".discussion-drawer")).toHaveLength(1);
+    expect(container.querySelectorAll(".discussion-message")).toHaveLength(2);
+    const expand = screen.getByRole("button", { name: "展开讨论为全屏" });
+    fireEvent.pointerDown(expand, { clientY: 300 });
+    fireEvent.pointerUp(expand, { clientY: 240 });
+    expect(container.querySelector(".discussion-drawer")).toHaveClass("discussion-drawer-expanded");
+    expect(screen.getByRole("button", { name: "收起讨论窗口" })).toBeInTheDocument();
+    expect(screen.getByText("哥哥正在回复并保存到这里…")).toBeInTheDocument();
+    const input = screen.getByPlaceholderText("回复哥哥……");
+    fireEvent.change(input, { target: { value: "那我们继续读。" } });
+    fireEvent.click(screen.getByRole("button", { name: "发送" }));
+    expect(onSend).toHaveBeenCalledWith("那我们继续读。");
+    fireEvent.click(screen.getByRole("button", { name: "结束并保存本轮共读" }));
+    expect(onCloseRound).toHaveBeenCalledOnce();
+  });
+});
