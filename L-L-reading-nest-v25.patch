 }
+
+function buildLegacyDiscussionGroups(
+  bundle: SessionBundle,
+  comments: CompanionComment[],
+  discussions: ReadingDiscussionSummary[]
+) {
+  const anchoredCommentIds = new Set(
+    discussions.map((summary) => summary.discussion.anchorCommentId)
+  );
+  const groups = new Map<string, { key: string; label: string; lines: string[] }>();
+  const add = (kind: string, index: number, label: string, line: string) => {
+    const key = `${kind}:${index}`;
+    const group = groups.get(key) ?? { key, label, lines: [] };
+    if (!group.lines.includes(line)) group.lines.push(line);
+    groups.set(key, group);
+  };
+  for (const comment of comments) {
+    if (anchoredCommentIds.has(comment.id)) continue;
+    add(
+      comment.position.kind,
+      comment.position.index,
+      comment.position.label,
+      `林序言：${comment.mode === "deep_analysis" ? "已生成长评，可回聊天区查看。" : comment.text}`
+    );
+  }
+  for (const reaction of bundle.reactions) {
+    add(
+      reaction.position.kind,
+      reaction.position.index,
+      reaction.position.label,
+      `小闪：${reaction.content}`
+    );
+  }
+  return [...groups.values()].sort((left, right) => {
+    const leftIndex = Number(left.key.split(":")[1] ?? 0);
+    const rightIndex = Number(right.key.split(":")[1] ?? 0);
+    return rightIndex - leftIndex;
+  });
+}
+
+function formatRecordTime(value: string) {
+  const date = new Date(value);
+  if (Number.isNaN(date.getTime())) return "刚刚更新";
+  return `最后讨论于 ${date.toLocaleString("zh-CN", {
+    month: "numeric",
+    day: "numeric",
+    hour: "2-digit",
+    minute: "2-digit"
+  })}`;
+}
