diff --git a/server/migrations/0002_private_assets.sql b/server/migrations/0002_private_assets.sql
new file mode 100644
index 0000000..e0f7f93
--- /dev/null
+++ b/server/migrations/0002_private_assets.sql
@@ -0,0 +1,23 @@
+CREATE TABLE IF NOT EXISTS private_assets (
+  object_key TEXT PRIMARY KEY,
+  body BLOB NOT NULL,
+  content_type TEXT,
+  size_bytes INTEGER NOT NULL,
+  metadata_json TEXT,
+  updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
+);
+
+CREATE INDEX IF NOT EXISTS private_assets_updated_at_idx
+  ON private_assets(updated_at);
+
+-- D1 limits the size of one BLOB value. Larger private sources are therefore
+-- split into small ordered rows while private_assets keeps their metadata.
+CREATE TABLE IF NOT EXISTS private_asset_chunks (
+  object_key TEXT NOT NULL,
+  chunk_index INTEGER NOT NULL,
+  body BLOB NOT NULL,
+  PRIMARY KEY (object_key, chunk_index)
+);
+
+CREATE INDEX IF NOT EXISTS private_asset_chunks_object_key_idx
+  ON private_asset_chunks(object_key);
diff --git a/server/migrations/0003_reading_discussions.sql b/server/migrations/0003_reading_discussions.sql
new file mode 100644
index 0000000..ea64a1d
--- /dev/null
+++ b/server/migrations/0003_reading_discussions.sql
@@ -0,0 +1,37 @@
+CREATE TABLE IF NOT EXISTS reading_discussions (
+  id TEXT PRIMARY KEY,
+  session_id TEXT NOT NULL,
+  position_kind TEXT NOT NULL CHECK (position_kind IN ('paragraph', 'page')),
+  position_index INTEGER NOT NULL CHECK (position_index >= 1),
+  position_total INTEGER,
+  position_label TEXT NOT NULL,
+  anchor_comment_id TEXT NOT NULL,
+  anchor_text TEXT NOT NULL,
+  mood TEXT CHECK (mood IS NULL OR mood IN ('like', 'resonance', 'funny', 'confused', 'shocked', 'upset')),
+  status TEXT NOT NULL DEFAULT 'open' CHECK (status IN ('open', 'closed')),
+  current_round INTEGER NOT NULL DEFAULT 1 CHECK (current_round >= 1),
+  created_at TEXT NOT NULL,
+  updated_at TEXT NOT NULL,
+  closed_at TEXT,
+  UNIQUE (session_id, position_kind, position_index, anchor_comment_id)
+);
+
+CREATE INDEX IF NOT EXISTS reading_discussions_session_position_idx
+  ON reading_discussions(session_id, position_kind, position_index, updated_at DESC);
+
+CREATE TABLE IF NOT EXISTS reading_discussion_messages (
+  id TEXT PRIMARY KEY,
+  discussion_id TEXT NOT NULL,
+  sequence INTEGER NOT NULL CHECK (sequence >= 1),
+  round_number INTEGER NOT NULL CHECK (round_number >= 1),
+  role TEXT NOT NULL CHECK (role IN ('user', 'assistant')),
+  kind TEXT NOT NULL CHECK (kind IN ('anchor', 'message')),
+  text TEXT NOT NULL,
+  operation_id TEXT NOT NULL UNIQUE,
+  created_at TEXT NOT NULL,
+  UNIQUE (discussion_id, sequence),
+  FOREIGN KEY (discussion_id) REFERENCES reading_discussions(id) ON DELETE CASCADE
+);
+
+CREATE INDEX IF NOT EXISTS reading_discussion_messages_order_idx
+  ON reading_discussion_messages(discussion_id, sequence);
