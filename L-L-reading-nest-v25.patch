@@ -0,0 +1,127 @@
+import type {
+  ReadingDiscussionDetail,
+  ReadingDiscussionMood,
+  ReadingPosition
+} from "@ss/shared";
+import { AppError } from "../errors/app-error.js";
+import type { ReadingDiscussionRepository } from "../repositories/reading-discussion-repository.js";
+import type { ReadingRepository } from "../repositories/reading-repository.js";
+
+export const DISCUSSION_REPLY_OPERATION_PREFIX = "discussion-reply:";
+
+export class ReadingDiscussionService {
+  constructor(
+    private readonly readingRepository: ReadingRepository,
+    private readonly discussionRepository: ReadingDiscussionRepository
+  ) {}
+
+  async getOrCreate(input: {
+    sessionId: string;
+    position: ReadingPosition;
+    anchorCommentId: string;
+    anchorText: string;
+  }) {
+    const database = await this.readingRepository.read();
+    const session = database.sessions.find((candidate) => candidate.id === input.sessionId);
+    if (!session) throw new AppError("SESSION_NOT_FOUND", "找不到这本书的共读记录。");
+    const anchor = database.companionComments.find(
+      (comment) =>
+        comment.id === input.anchorCommentId &&
+        comment.sessionId === input.sessionId &&
+        comment.position.kind === input.position.kind &&
+        comment.position.index === input.position.index
+    );
+    if (!anchor) {
+      throw new AppError("INVALID_OPERATION", "这条林序言短评不属于当前阅读位置。");
+    }
+    if (anchor.text !== input.anchorText) {
+      throw new AppError("INVALID_OPERATION", "林序言短评内容校验失败，请刷新后重试。");
+    }
+    return this.discussionRepository.getOrCreate(input);
+  }
+
+  async getDetail(discussionId: string): Promise<ReadingDiscussionDetail> {
+    const detail = await this.discussionRepository.getDetail(discussionId);
+    if (!detail) throw new AppError("INVALID_OPERATION", "找不到这段共读讨论。");
+    return detail;
+  }
+
+  async setMood(discussionId: string, mood: ReadingDiscussionMood | null) {
+    const discussion = await this.discussionRepository.setMood(discussionId, mood);
+    if (!discussion) throw new AppError("INVALID_OPERATION", "找不到这段共读讨论。");
+    return discussion;
+  }
+
+  async appendUserMessage(input: {
+    discussionId: string;
+    text: string;
+    operationId: string;
+  }) {
+    const message = await this.discussionRepository.appendMessage({
+      ...input,
+      text: input.text.trim(),
+      role: "user"
+    });
+    if (!message) throw new AppError("INVALID_OPERATION", "找不到这段共读讨论。");
+    return { message, detail: await this.getDetail(input.discussionId) };
+  }
+
+  async publishAssistantReply(input: {
+    discussionId: string;
+    sessionId: string;
+    position: ReadingPosition;
+    text: string;
+    operationId: string;
+  }) {
+    const detail = await this.getDetail(input.discussionId);
+    const { discussion } = detail;
+    if (
+      discussion.sessionId !== input.sessionId ||
+      discussion.position.kind !== input.position.kind ||
+      discussion.position.index !== input.position.index
+    ) {
+      throw new AppError("INVALID_OPERATION", "讨论回复与当前书籍位置不一致。");
+    }
+    const parsed = parseDiscussionReplyOperationId(input.operationId);
+    if (!parsed || parsed.discussionId !== input.discussionId) {
+      throw new AppError("INVALID_OPERATION", "讨论回复操作号无效。");
+    }
+    const message = await this.discussionRepository.appendMessage({
+      discussionId: input.discussionId,
+      role: "assistant",
+      text: input.text.trim(),
+      operationId: input.operationId
+    });
+    if (!message) throw new AppError("INVALID_OPERATION", "找不到这段共读讨论。");
+    return { message, detail: await this.getDetail(input.discussionId) };
+  }
+
+  async close(discussionId: string) {
+    const discussion = await this.discussionRepository.close(discussionId);
+    if (!discussion) throw new AppError("INVALID_OPERATION", "找不到这段共读讨论。");
+    return discussion;
+  }
+
+  async listBySession(sessionId: string) {
+    const database = await this.readingRepository.read();
+    if (!database.sessions.some((session) => session.id === sessionId)) {
+      throw new AppError("SESSION_NOT_FOUND", "找不到这本书的共读记录。");
+    }
+    return this.discussionRepository.listBySession(sessionId);
+  }
+
+  async deleteBySession(sessionId: string) {
+    await this.discussionRepository.deleteBySession(sessionId);
+  }
+}
+
+export function parseDiscussionReplyOperationId(operationId: string) {
+  if (!operationId.startsWith(DISCUSSION_REPLY_OPERATION_PREFIX)) return null;
+  const remainder = operationId.slice(DISCUSSION_REPLY_OPERATION_PREFIX.length);
+  const separator = remainder.indexOf(":");
+  if (separator <= 0 || separator === remainder.length - 1) return null;
+  return {
+    discussionId: remainder.slice(0, separator),
+    requestId: remainder.slice(separator + 1)
+  };
+}
