@@ -0,0 +1,143 @@
+import { useEffect, useLayoutEffect, useRef, useState } from "react";
+import type { ReadingDiscussionDetail } from "@ss/shared";
+
+const drawerScrollPositions = new Map<string, number>();
+
+export function DiscussionDrawer(props: {
+  bookTitle: string;
+  detail: ReadingDiscussionDetail;
+  loading?: boolean;
+  sending?: boolean;
+  awaitingReply?: boolean;
+  error?: string;
+  onSend: (text: string) => void;
+  onCloseRound: () => void;
+  onClose: () => void;
+}) {
+  const [draft, setDraft] = useState("");
+  const [expanded, setExpanded] = useState(false);
+  const listRef = useRef<HTMLDivElement>(null);
+  const dragStartY = useRef<number | null>(null);
+  const wasNearBottom = useRef(true);
+
+  useLayoutEffect(() => {
+    const list = listRef.current;
+    if (!list) return;
+    const saved = drawerScrollPositions.get(props.detail.discussion.id);
+    list.scrollTop = saved ?? list.scrollHeight;
+    wasNearBottom.current =
+      saved === undefined || list.scrollHeight - list.scrollTop - list.clientHeight < 40;
+    return () => {
+      drawerScrollPositions.set(props.detail.discussion.id, list.scrollTop);
+    };
+  }, [props.detail.discussion.id]);
+
+  useEffect(() => {
+    const list = listRef.current;
+    if (list && wasNearBottom.current) list.scrollTop = list.scrollHeight;
+  }, [props.detail.messages.length]);
+
+  const send = () => {
+    const text = draft.trim();
+    if (!text || props.sending) return;
+    setDraft("");
+    props.onSend(text);
+  };
+
+  return (
+    <div className="discussion-drawer-backdrop" role="presentation" onClick={props.onClose}>
+      <section
+        className={`discussion-drawer${expanded ? " discussion-drawer-expanded" : ""}`}
+        role="dialog"
+        aria-modal="true"
+        aria-label={`和哥哥聊${props.detail.discussion.position.label}`}
+        onClick={(event) => event.stopPropagation()}
+      >
+        <button
+          type="button"
+          className="discussion-drawer-grip"
+          aria-label={expanded ? "收起讨论窗口" : "展开讨论为全屏"}
+          onPointerDown={(event) => {
+            dragStartY.current = event.clientY;
+          }}
+          onPointerUp={(event) => {
+            const start = dragStartY.current;
+            dragStartY.current = null;
+            if (start === null) return;
+            const distance = event.clientY - start;
+            if (distance <= -28) setExpanded(true);
+            else if (distance >= 28) setExpanded(false);
+            else setExpanded((value) => !value);
+          }}
+        />
+        <header className="discussion-drawer-header">
+          <div>
+            <span>{props.bookTitle}</span>
+            <h2>和哥哥聊{props.detail.discussion.position.label}</h2>
+          </div>
+          <button type="button" aria-label="关闭讨论" onClick={props.onClose}>×</button>
+        </header>
+
+        <div
+          className="discussion-message-list"
+          ref={listRef}
+          aria-live="polite"
+          onScroll={(event) => {
+            const list = event.currentTarget;
+            drawerScrollPositions.set(props.detail.discussion.id, list.scrollTop);
+            wasNearBottom.current = list.scrollHeight - list.scrollTop - list.clientHeight < 40;
+          }}
+        >
+          {props.detail.messages.map((message, index) => {
+            const previous = props.detail.messages[index - 1];
+            const showRound = index > 0 && previous?.roundNumber !== message.roundNumber;
+            return (
+              <div key={message.id}>
+                {showRound ? (
+                  <div className="discussion-round-divider">第 {message.roundNumber} 轮共读</div>
+                ) : null}
+                <article className={`discussion-message discussion-message-${message.role}`}>
+                  <strong>{message.role === "assistant" ? "林序言" : "小闪"}</strong>
+                  <p>{message.text}</p>
+                </article>
+              </div>
+            );
+          })}
+          {props.loading ? <p className="discussion-drawer-status">正在同步完整讨论…</p> : null}
+          {props.awaitingReply ? <p className="discussion-drawer-status">哥哥正在回复并保存到这里…</p> : null}
+          {props.error ? <p className="discussion-drawer-error">{props.error}</p> : null}
+        </div>
+
+        <footer className="discussion-composer">
+          <label>
+            <span className="sr-only">回复哥哥</span>
+            <textarea
+              value={draft}
+              maxLength={4000}
+              rows={2}
+              placeholder="回复哥哥……"
+              onChange={(event) => setDraft(event.target.value)}
+              onKeyDown={(event) => {
+                if (event.key === "Enter" && !event.shiftKey) {
+                  event.preventDefault();
+                  send();
+                }
+              }}
+            />
+          </label>
+          <button
+            type="button"
+            className="discussion-send-button"
+            disabled={!draft.trim() || props.sending}
+            onClick={send}
+          >
+            {props.sending ? "保存中…" : "发送"}
+          </button>
+          <button type="button" className="discussion-close-round" onClick={props.onCloseRound}>
+            结束并保存本轮共读
+          </button>
+        </footer>
+      </section>
+    </div>
+  );
+}
