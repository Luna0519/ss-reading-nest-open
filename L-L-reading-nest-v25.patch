@@ -0,0 +1,95 @@
+import type {
+  CompanionComment,
+  ReadingDiscussionMood,
+  ReadingDiscussionSummary
+} from "@ss/shared";
+
+const moodOptions: Array<{
+  value: ReadingDiscussionMood;
+  emoji: string;
+  label: string;
+}> = [
+  { value: "like", emoji: "❤️", label: "喜欢" },
+  { value: "resonance", emoji: "🥹", label: "共鸣" },
+  { value: "funny", emoji: "😂", label: "好笑" },
+  { value: "confused", emoji: "🤔", label: "没看懂" },
+  { value: "shocked", emoji: "😮", label: "震惊" },
+  { value: "upset", emoji: "😠", label: "不爽" }
+];
+
+export function ReadingDiscussionCard(props: {
+  anchor?: CompanionComment;
+  summary?: ReadingDiscussionSummary;
+  loading?: boolean;
+  error?: string;
+  busy?: boolean;
+  onMood: (anchor: CompanionComment, mood: ReadingDiscussionMood | null) => void;
+  onReply: (anchor: CompanionComment) => void;
+}) {
+  const selectedMood = props.summary?.discussion.mood ?? null;
+  const messageCount = props.summary?.messageCount ?? 0;
+
+  return (
+    <section className="reading-discussion-card" aria-label="林序言陪读">
+      <header>
+        <div>
+          <strong>林序言陪读</strong>
+          <span>{props.anchor?.position.label ?? "当前位置"}</span>
+        </div>
+        {messageCount > 1 ? <span className="discussion-count">已讨论 {messageCount} 条</span> : null}
+      </header>
+
+      {props.loading ? <p className="discussion-muted">正在看看哥哥留下了什么……</p> : null}
+      {!props.loading && props.error ? <p className="discussion-error">{props.error}</p> : null}
+      {!props.loading && !props.error && !props.anchor ? (
+        <p className="discussion-muted">点一下“陪我看看这里”，林序言的短评会留在这里。</p>
+      ) : null}
+      {props.anchor ? (
+        <>
+          <p className="discussion-anchor-text">
+            {props.anchor.mode === "deep_analysis"
+              ? "已生成长评，可回聊天区查看。"
+              : props.anchor.text}
+          </p>
+          <div className="discussion-moods" aria-label="选择这一段的心情">
+            {moodOptions.map((option) => {
+              const selected = selectedMood === option.value;
+              return (
+                <button
+                  type="button"
+                  key={option.value}
+                  aria-pressed={selected}
+                  disabled={props.busy}
+                  onClick={() => props.onMood(props.anchor!, selected ? null : option.value)}
+                >
+                  <span aria-hidden="true">{option.emoji}</span>
+                  {option.label}
+                </button>
+              );
+            })}
+          </div>
+          <div className="discussion-card-actions">
+            <button
+              type="button"
+              className="discussion-reply-button"
+              disabled={props.busy}
+              onClick={() => props.onReply(props.anchor!)}
+            >
+              回复哥哥
+            </button>
+            <button
+              type="button"
+              className="discussion-light-button"
+              disabled={props.busy}
+              onClick={() => props.onReply(props.anchor!)}
+            >
+              {messageCount > 1 ? `查看完整讨论 · ${messageCount} 条` : "开始来回聊"}
+            </button>
+          </div>
+        </>
+      ) : null}
+    </section>
+  );
+}
+
+export { moodOptions as readingDiscussionMoodOptions };
