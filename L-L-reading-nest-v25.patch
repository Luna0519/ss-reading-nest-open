@@ -0,0 +1,152 @@
+import type {
+  ReadingDiscussion,
+  ReadingDiscussionDetail,
+  ReadingDiscussionMessage,
+  ReadingDiscussionMood,
+  ReadingDiscussionSummary
+} from "@ss/shared";
+import type {
+  AppendReadingDiscussionMessageInput,
+  CreateReadingDiscussionInput,
+  ReadingDiscussionRepository
+} from "./reading-discussion-repository.js";
+
+export class MemoryReadingDiscussionRepository implements ReadingDiscussionRepository {
+  private readonly discussions = new Map<string, ReadingDiscussion>();
+  private readonly messages = new Map<string, ReadingDiscussionMessage[]>();
+
+  async getOrCreate(input: CreateReadingDiscussionInput): Promise<ReadingDiscussionDetail> {
+    const existing = [...this.discussions.values()].find(
+      (discussion) =>
+        discussion.sessionId === input.sessionId &&
+        discussion.position.kind === input.position.kind &&
+        discussion.position.index === input.position.index &&
+        discussion.anchorCommentId === input.anchorCommentId
+    );
+    if (existing) return this.detail(existing);
+
+    const now = new Date().toISOString();
+    const discussion: ReadingDiscussion = {
+      id: crypto.randomUUID(),
+      sessionId: input.sessionId,
+      position: { ...input.position },
+      anchorCommentId: input.anchorCommentId,
+      anchorText: input.anchorText,
+      mood: null,
+      status: "open",
+      currentRound: 1,
+      createdAt: now,
+      updatedAt: now
+    };
+    const anchor: ReadingDiscussionMessage = {
+      id: crypto.randomUUID(),
+      discussionId: discussion.id,
+      sequence: 1,
+      roundNumber: 1,
+      role: "assistant",
+      kind: "anchor",
+      text: input.anchorText,
+      operationId: `discussion-anchor:${input.anchorCommentId}`,
+      createdAt: now
+    };
+    this.discussions.set(discussion.id, discussion);
+    this.messages.set(discussion.id, [anchor]);
+    return this.detail(discussion);
+  }
+
+  async get(discussionId: string) {
+    return this.discussions.get(discussionId) ?? null;
+  }
+
+  async getDetail(discussionId: string) {
+    const discussion = this.discussions.get(discussionId);
+    return discussion ? this.detail(discussion) : null;
+  }
+
+  async setMood(discussionId: string, mood: ReadingDiscussionMood | null) {
+    const discussion = this.discussions.get(discussionId);
+    if (!discussion) return null;
+    const updated = { ...discussion, mood, updatedAt: new Date().toISOString() };
+    this.discussions.set(discussionId, updated);
+    return updated;
+  }
+
+  async appendMessage(input: AppendReadingDiscussionMessageInput) {
+    for (const list of this.messages.values()) {
+      const existing = list.find((message) => message.operationId === input.operationId);
+      if (existing) return existing;
+    }
+    const discussion = this.discussions.get(input.discussionId);
+    if (!discussion) return null;
+    const now = new Date().toISOString();
+    const currentRound =
+      discussion.status === "closed" ? discussion.currentRound + 1 : discussion.currentRound;
+    const list = this.messages.get(input.discussionId) ?? [];
+    const message: ReadingDiscussionMessage = {
+      id: crypto.randomUUID(),
+      discussionId: input.discussionId,
+      sequence: list.length + 1,
+      roundNumber: currentRound,
+      role: input.role,
+      kind: "message",
+      text: input.text,
+      operationId: input.operationId,
+      createdAt: now
+    };
+    list.push(message);
+    this.messages.set(input.discussionId, list);
+    this.discussions.set(input.discussionId, {
+      ...discussion,
+      status: "open",
+      currentRound,
+      updatedAt: now,
+      closedAt: undefined
+    });
+    return message;
+  }
+
+  async close(discussionId: string) {
+    const discussion = this.discussions.get(discussionId);
+    if (!discussion) return null;
+    const now = new Date().toISOString();
+    const updated: ReadingDiscussion = {
+      ...discussion,
+      status: "closed",
+      updatedAt: now,
+      closedAt: now
+    };
+    this.discussions.set(discussionId, updated);
+    return updated;
+  }
+
+  async listBySession(sessionId: string): Promise<ReadingDiscussionSummary[]> {
+    return [...this.discussions.values()]
+      .filter((discussion) => discussion.sessionId === sessionId)
+      .sort((left, right) => right.updatedAt.localeCompare(left.updatedAt))
+      .map((discussion) => {
+        const messages = this.messages.get(discussion.id) ?? [];
+        return {
+          discussion,
+          messageCount: messages.length,
+          lastMessageAt: messages.at(-1)?.createdAt ?? discussion.updatedAt
+        };
+      });
+  }
+
+  async deleteBySession(sessionId: string) {
+    for (const discussion of [...this.discussions.values()]) {
+      if (discussion.sessionId !== sessionId) continue;
+      this.discussions.delete(discussion.id);
+      this.messages.delete(discussion.id);
+    }
+  }
+
+  private detail(discussion: ReadingDiscussion): ReadingDiscussionDetail {
+    return {
+      discussion,
+      messages: [...(this.messages.get(discussion.id) ?? [])].sort(
+        (left, right) => left.sequence - right.sequence
+      )
+    };
+  }
+}
