diff --git a/server/src/mcp/ui-template.integration.test.ts b/server/src/mcp/ui-template.integration.test.ts
new file mode 100644
index 0000000..3d8427c
--- /dev/null
+++ b/server/src/mcp/ui-template.integration.test.ts
@@ -0,0 +1,67 @@
+import { Client } from "@modelcontextprotocol/sdk/client/index.js";
+import { InMemoryTransport } from "@modelcontextprotocol/sdk/inMemory.js";
+import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
+import { describe, expect, it } from "vitest";
+import {
+  buildInlineWidgetHtml,
+  WIDGET_SCRIPT_PATH,
+  WIDGET_STYLE_PATH
+} from "../widget-assets.js";
+import { registerReadingResource } from "./register-resource.js";
+import { READING_NEST_URI, registerReadingTools } from "./register-tools.js";
+
+describe("ChatGPT UI template MCP chain", () => {
+  it("keeps the tool, listed resource, and readable HTML on one exact URI", async () => {
+    const server = new McpServer({ name: "L&L UI integration test", version: "0.2.18" });
+    const widgetHtml = buildInlineWidgetHtml(
+      `<!doctype html><html><head><link rel="stylesheet" href="${WIDGET_STYLE_PATH}"></head><body><div id="root"></div><script type="module" src="${WIDGET_SCRIPT_PATH}"></script></body></html>`,
+      {
+        script: "document.querySelector('#root')?.setAttribute('data-ready', 'true');",
+        styles: "#root{display:block}"
+      }
+    );
+    registerReadingResource(server, widgetHtml, "https://reading-nest.example.workers.dev");
+    registerReadingTools(server, {} as never, {} as never);
+
+    const client = new Client({ name: "L&L UI integration client", version: "0.2.18" });
+    const [clientTransport, serverTransport] = InMemoryTransport.createLinkedPair();
+
+    try {
+      await server.connect(serverTransport);
+      await client.connect(clientTransport);
+
+      const tools = await client.listTools();
+      const openTool = tools.tools.find((tool) => tool.name === "open_reading_nest");
+      expect(openTool?._meta?.ui).toEqual({
+        resourceUri: READING_NEST_URI,
+        visibility: ["model", "app"]
+      });
+      expect(openTool?._meta?.["ui/resourceUri"]).toBe(READING_NEST_URI);
+      expect(openTool?._meta?.["openai/outputTemplate"]).toBe(READING_NEST_URI);
+      expect(openTool?._meta?.["openai/widgetAccessible"]).toBe(true);
+      expect(openTool?.outputSchema).toMatchObject({
+        type: "object",
+        required: ["bookshelfSessions", "recentSessions"]
+      });
+
+      const resources = await client.listResources();
+      expect(resources.resources.some((resource) => resource.uri === READING_NEST_URI)).toBe(true);
+
+      const result = await client.readResource({ uri: READING_NEST_URI });
+      const template = result.contents.find((content) => content.uri === READING_NEST_URI);
+      expect(template?.uri).toBe(READING_NEST_URI);
+      expect(template?.mimeType).toBe("text/html;profile=mcp-app");
+      expect("text" in (template ?? {}) ? template?.text : undefined).toBe(widgetHtml);
+      expect("text" in (template ?? {}) ? template?.text : "").toMatch(/^<!doctype html>/i);
+      expect("text" in (template ?? {}) ? template?.text : "").toContain(
+        "data-ll-widget-script"
+      );
+      expect("text" in (template ?? {}) ? template?.text : "").not.toMatch(
+        /<(?:script|link)\b[^>]*(?:src|href)=/i
+      );
+    } finally {
+      await client.close();
+      await server.close();
+    }
+  });
+});
diff --git a/server/src/repositories/d1-reading-discussion-repository.ts b/server/src/repositories/d1-reading-discussion-repository.ts
new file mode 100644
index 0000000..92a253f
--- /dev/null
+++ b/server/src/repositories/d1-reading-discussion-repository.ts
@@ -0,0 +1,296 @@
+import type {
+  ReadingDiscussion,
+  ReadingDiscussionDetail,
+  ReadingDiscussionMessage,
+  ReadingDiscussionMood,
+  ReadingDiscussionSummary
+} from "@ss/shared";
+import type {
+  AppendReadingDiscussionMessageInput,
+  CreateReadingDiscussionInput,
+  ReadingDiscussionRepository
+} from "./reading-discussion-repository.js";
+
+type D1RunResultLike = { success: boolean; meta: { changes?: number } };
+type D1AllResultLike<T> = { success: boolean; results: T[] };
+type D1StatementLike = {
+  bind(...values: unknown[]): D1StatementLike;
+  first<T>(): Promise<T | null>;
+  run(): Promise<D1RunResultLike>;
+  all<T>(): Promise<D1AllResultLike<T>>;
+};
+export interface D1DiscussionDatabaseLike {
+  prepare(sql: string): D1StatementLike;
+}
+
+type DiscussionRow = {
+  id: string;
+  session_id: string;
+  position_kind: "paragraph" | "page";
+  position_index: number;
+  position_total: number | null;
+  position_label: string;
+  anchor_comment_id: string;
+  anchor_text: string;
+  mood: ReadingDiscussionMood | null;
+  status: "open" | "closed";
+  current_round: number;
+  created_at: string;
+  updated_at: string;
+  closed_at: string | null;
+};
+
+type MessageRow = {
+  id: string;
+  discussion_id: string;
+  sequence: number;
+  round_number: number;
+  role: "user" | "assistant";
+  kind: "anchor" | "message";
+  text: string;
+  operation_id: string;
+  created_at: string;
+};
+
+type SummaryRow = DiscussionRow & {
+  message_count: number;
+  last_message_at: string;
+};
+
+export class D1ReadingDiscussionRepository implements ReadingDiscussionRepository {
+  constructor(private readonly database: D1DiscussionDatabaseLike) {}
+
+  async getOrCreate(input: CreateReadingDiscussionInput): Promise<ReadingDiscussionDetail> {
+    const existing = await this.findByAnchor(input);
+    if (existing) return (await this.getDetail(existing.id))!;
+
+    const now = new Date().toISOString();
+    const discussionId = crypto.randomUUID();
+    await this.database
+      .prepare(
+        `INSERT OR IGNORE INTO reading_discussions (
+          id, session_id, position_kind, position_index, position_total, position_label,
+          anchor_comment_id, anchor_text, mood, status, current_round, created_at, updated_at
+        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, NULL, 'open', 1, ?, ?)`
+      )
+      .bind(
+        discussionId,
+        input.sessionId,
+        input.position.kind,
+        input.position.index,
+        input.position.total ?? null,
+        input.position.label,
+        input.anchorCommentId,
+        input.anchorText,
+        now,
+        now
+      )
+      .run();
+    const discussion = (await this.findByAnchor(input))!;
+    await this.database
+      .prepare(
+        `INSERT OR IGNORE INTO reading_discussion_messages (
+          id, discussion_id, sequence, round_number, role, kind, text, operation_id, created_at
+        ) VALUES (?, ?, 1, 1, 'assistant', 'anchor', ?, ?, ?)`
+      )
+      .bind(
+        crypto.randomUUID(),
+        discussion.id,
+        input.anchorText,
+        `discussion-anchor:${input.anchorCommentId}`,
+        now
+      )
+      .run();
+    return (await this.getDetail(discussion.id))!;
+  }
+
+  async get(discussionId: string) {
+    const row = await this.database
+      .prepare("SELECT * FROM reading_discussions WHERE id = ?")
+      .bind(discussionId)
+      .first<DiscussionRow>();
+    return row ? mapDiscussion(row) : null;
+  }
+
+  async getDetail(discussionId: string): Promise<ReadingDiscussionDetail | null> {
+    const discussion = await this.get(discussionId);
+    if (!discussion) return null;
+    const rows = await this.database
+      .prepare(
+        "SELECT * FROM reading_discussion_messages WHERE discussion_id = ? ORDER BY sequence ASC"
+      )
+      .bind(discussionId)
+      .all<MessageRow>();
+    return { discussion, messages: rows.results.map(mapMessage) };
+  }
+
+  async setMood(discussionId: string, mood: ReadingDiscussionMood | null) {
+    const now = new Date().toISOString();
+    await this.database
+      .prepare("UPDATE reading_discussions SET mood = ?, updated_at = ? WHERE id = ?")
+      .bind(mood, now, discussionId)
+      .run();
+    return this.get(discussionId);
+  }
+
+  async appendMessage(input: AppendReadingDiscussionMessageInput) {
+    const existing = await this.findMessageByOperationId(input.operationId);
+    if (existing) return existing;
+    const discussion = await this.get(input.discussionId);
+    if (!discussion) return null;
+
+    const now = new Date().toISOString();
+    const roundNumber =
+      discussion.status === "closed" ? discussion.currentRound + 1 : discussion.currentRound;
+    if (discussion.status === "closed") {
+      await this.database
+        .prepare(
+          "UPDATE reading_discussions SET status = 'open', current_round = ?, closed_at = NULL, updated_at = ? WHERE id = ?"
+        )
+        .bind(roundNumber, now, input.discussionId)
+        .run();
+    }
+
+    for (let attempt = 0; attempt < 3; attempt += 1) {
+      const sequenceRow = await this.database
+        .prepare(
+          "SELECT COALESCE(MAX(sequence), 0) + 1 AS next_sequence FROM reading_discussion_messages WHERE discussion_id = ?"
+        )
+        .bind(input.discussionId)
+        .first<{ next_sequence: number }>();
+      const sequence = sequenceRow?.next_sequence ?? 1;
+      try {
+        await this.database
+          .prepare(
+            `INSERT INTO reading_discussion_messages (
+              id, discussion_id, sequence, round_number, role, kind, text, operation_id, created_at
+            ) VALUES (?, ?, ?, ?, ?, 'message', ?, ?, ?)`
+          )
+          .bind(
+            crypto.randomUUID(),
+            input.discussionId,
+            sequence,
+            roundNumber,
+            input.role,
+            input.text,
+            input.operationId,
+            now
+          )
+          .run();
+        await this.database
+          .prepare("UPDATE reading_discussions SET updated_at = ? WHERE id = ?")
+          .bind(now, input.discussionId)
+          .run();
+        return (await this.findMessageByOperationId(input.operationId))!;
+      } catch (error) {
+        const duplicate = await this.findMessageByOperationId(input.operationId);
+        if (duplicate) return duplicate;
+        if (attempt === 2) throw error;
+      }
+    }
+    return null;
+  }
+
+  async close(discussionId: string) {
+    const now = new Date().toISOString();
+    await this.database
+      .prepare(
+        "UPDATE reading_discussions SET status = 'closed', closed_at = ?, updated_at = ? WHERE id = ?"
+      )
+      .bind(now, now, discussionId)
+      .run();
+    return this.get(discussionId);
+  }
+
+  async listBySession(sessionId: string): Promise<ReadingDiscussionSummary[]> {
+    const rows = await this.database
+      .prepare(
+        `SELECT d.*, COUNT(m.id) AS message_count,
+          COALESCE(MAX(m.created_at), d.updated_at) AS last_message_at
+        FROM reading_discussions d
+        LEFT JOIN reading_discussion_messages m ON m.discussion_id = d.id
+        WHERE d.session_id = ?
+        GROUP BY d.id
+        ORDER BY d.updated_at DESC`
+      )
+      .bind(sessionId)
+      .all<SummaryRow>();
+    return rows.results.map((row) => ({
+      discussion: mapDiscussion(row),
+      messageCount: Number(row.message_count),
+      lastMessageAt: row.last_message_at
+    }));
+  }
+
+  async deleteBySession(sessionId: string) {
+    await this.database
+      .prepare(
+        "DELETE FROM reading_discussion_messages WHERE discussion_id IN (SELECT id FROM reading_discussions WHERE session_id = ?)"
+      )
+      .bind(sessionId)
+      .run();
+    await this.database
+      .prepare("DELETE FROM reading_discussions WHERE session_id = ?")
+      .bind(sessionId)
+      .run();
+  }
+
+  private async findByAnchor(input: CreateReadingDiscussionInput) {
+    const row = await this.database
+      .prepare(
+        `SELECT * FROM reading_discussions
+        WHERE session_id = ? AND position_kind = ? AND position_index = ? AND anchor_comment_id = ?`
+      )
+      .bind(
+        input.sessionId,
+        input.position.kind,
+        input.position.index,
+        input.anchorCommentId
+      )
+      .first<DiscussionRow>();
+    return row ? mapDiscussion(row) : null;
+  }
+
+  private async findMessageByOperationId(operationId: string) {
+    const row = await this.database
+      .prepare("SELECT * FROM reading_discussion_messages WHERE operation_id = ?")
+      .bind(operationId)
+      .first<MessageRow>();
+    return row ? mapMessage(row) : null;
+  }
+}
+
+function mapDiscussion(row: DiscussionRow): ReadingDiscussion {
+  return {
+    id: row.id,
+    sessionId: row.session_id,
+    position: {
+      kind: row.position_kind,
+      index: Number(row.position_index),
+      ...(row.position_total === null ? {} : { total: Number(row.position_total) }),
+      label: row.position_label
+    },
+    anchorCommentId: row.anchor_comment_id,
+    anchorText: row.anchor_text,
+    mood: row.mood,
+    status: row.status,
+    currentRound: Number(row.current_round),
+    createdAt: row.created_at,
+    updatedAt: row.updated_at,
+    ...(row.closed_at ? { closedAt: row.closed_at } : {})
+  };
+}
+
+function mapMessage(row: MessageRow): ReadingDiscussionMessage {
+  return {
+    id: row.id,
+    discussionId: row.discussion_id,
+    sequence: Number(row.sequence),
+    roundNumber: Number(row.round_number),
+    role: row.role,
+    kind: row.kind,
+    text: row.text,
+    operationId: row.operation_id,
+    createdAt: row.created_at
+  };
+}
