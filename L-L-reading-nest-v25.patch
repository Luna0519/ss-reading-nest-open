+import { describe, expect, it } from "vitest";
+import type { CompanionComment, ReadingDatabase } from "@ss/shared";
+import { DEFAULT_SESSION_PREFERENCES } from "@ss/shared";
+import { MemoryReadingDiscussionRepository } from "../repositories/memory-reading-discussion-repository.js";
+import type { ReadingRepository } from "../repositories/reading-repository.js";
+import {
+  parseDiscussionReplyOperationId,
+  ReadingDiscussionService
+} from "./reading-discussion-service.js";
+
+const anchor: CompanionComment = {
+  id: "comment-1",
+  sessionId: "session-1",
+  position: { kind: "paragraph", index: 2, total: 49, label: "第 2 段" },
+  mode: "light_chat",
+  length: "normal",
+  text: "这一段像一张精神地图。",
+  source: "current_context",
+  inRecent: true,
+  inHistory: true,
+  operationId: "comment-operation-1",
+  createdAt: "2026-07-18T00:00:00.000Z"
+};
+
+function createReadingRepository(): ReadingRepository {
+  const database: ReadingDatabase = {
+    schemaVersion: 4,
+    sessions: [
+      {
+        id: "session-1",
+        title: "悉达多",
+        type: "novel",
+        status: "active",
+        userCurrentPosition: anchor.position,
+        assistantSyncedPosition: anchor.position,
+        liveReadingEnabled: false,
+        sessionPreferences: structuredClone(DEFAULT_SESSION_PREFERENCES),
+        sourceManifest: null,
+        createdAt: "2026-07-18T00:00:00.000Z",
+        updatedAt: "2026-07-18T00:00:00.000Z",
+        lastReadAt: "2026-07-18T00:00:00.000Z"
+      }
+    ],
+    quotes: [],
+    reactions: [],
+    bookmarks: [],
+    companionComments: [anchor]
+  };
+  return {
+    async read() {
+      return database;
+    },
+    async mutate(change) {
+      return change(database);
+    }
+  };
+}
+
+describe("ReadingDiscussionService", () => {
+  it("creates one anchored discussion and reuses it idempotently", async () => {
+    const service = new ReadingDiscussionService(
+      createReadingRepository(),
+      new MemoryReadingDiscussionRepository()
+    );
+    const input = {
+      sessionId: anchor.sessionId,
+      position: anchor.position,
+      anchorCommentId: anchor.id,
+      anchorText: anchor.text
+    };
+
+    const first = await service.getOrCreate(input);
+    const second = await service.getOrCreate(input);
+
+    expect(second.discussion.id).toBe(first.discussion.id);
+    expect(second.messages).toHaveLength(1);
+    expect(second.messages[0]).toMatchObject({
+      role: "assistant",
+      kind: "anchor",
+      text: anchor.text,
+      sequence: 1
+    });
+  });
+
+  it("rejects an anchor that is not the saved comment at this position", async () => {
+    const service = new ReadingDiscussionService(
+      createReadingRepository(),
+      new MemoryReadingDiscussionRepository()
+    );
+
+    await expect(
+      service.getOrCreate({
+        sessionId: anchor.sessionId,
+        position: anchor.position,
+        anchorCommentId: "wrong-comment",
+        anchorText: anchor.text
+      })
+    ).rejects.toThrow("不属于当前阅读位置");
+  });
+
+  it("saves mood, ordered messages, idempotency, and a new round after close", async () => {
+    const service = new ReadingDiscussionService(
+      createReadingRepository(),
+      new MemoryReadingDiscussionRepository()
+    );
+    const opened = await service.getOrCreate({
+      sessionId: anchor.sessionId,
+      position: anchor.position,
+      anchorCommentId: anchor.id,
+      anchorText: anchor.text
+    });
+    const discussionId = opened.discussion.id;
+    await service.setMood(discussionId, "resonance");
+    const first = await service.appendUserMessage({
+      discussionId,
+      text: "我也觉得像精神地图。",
+      operationId: "user-message-1"
+    });
+    const repeated = await service.appendUserMessage({
+      discussionId,
+      text: "这条不会重复。",
+      operationId: "user-message-1"
+    });
+    await service.publishAssistantReply({
+      discussionId,
+      sessionId: anchor.sessionId,
+      position: anchor.position,
+      text: "嗯，它先把方向画给我们看。",
+      operationId: `discussion-reply:${discussionId}:reply-1`
+    });
+    await service.close(discussionId);
+    await service.appendUserMessage({
+      discussionId,
+      text: "那我们继续读。",
+      operationId: "user-message-2"
+    });
+
+    const detail = await service.getDetail(discussionId);
+    expect(first.message.id).toBe(repeated.message.id);
+    expect(detail.discussion).toMatchObject({
+      mood: "resonance",
+      status: "open",
+      currentRound: 2
+    });
+    expect(detail.messages.map((message) => message.role)).toEqual([
+      "assistant",
+      "user",
+      "assistant",
+      "user"
+    ]);
+    expect(detail.messages.map((message) => message.roundNumber)).toEqual([1, 1, 1, 2]);
+    expect(detail.messages.map((message) => message.sequence)).toEqual([1, 2, 3, 4]);
+  });
+
+  it("lists summaries and deletes only discussions for the removed session", async () => {
+    const repository = new MemoryReadingDiscussionRepository();
+    const service = new ReadingDiscussionService(createReadingRepository(), repository);
+    const opened = await service.getOrCreate({
+      sessionId: anchor.sessionId,
+      position: anchor.position,
+      anchorCommentId: anchor.id,
+      anchorText: anchor.text
+    });
+    const summaries = await service.listBySession(anchor.sessionId);
+    expect(summaries).toHaveLength(1);
+    expect(summaries[0]).toMatchObject({ messageCount: 1 });
+
+    await service.deleteBySession(anchor.sessionId);
+    expect(await repository.getDetail(opened.discussion.id)).toBeNull();
+  });
+});
+
+describe("parseDiscussionReplyOperationId", () => {
+  it("accepts only complete discussion reply operation ids", () => {
+    expect(parseDiscussionReplyOperationId("discussion-reply:thread-1:request-1")).toEqual({
+      discussionId: "thread-1",
+      requestId: "request-1"
+    });
+    expect(parseDiscussionReplyOperationId("ordinary-comment")).toBeNull();
+    expect(parseDiscussionReplyOperationId("discussion-reply:missing-request")).toBeNull();
+  });
+});
