diff --git a/server/migrations/0002_private_assets.sql b/server/migrations/0002_private_assets.sql
new file mode 100644
index 0000000..e0f7f93
--- /dev/null
+++ b/server/migrations/0002_private_assets.sql
@@ -0,0 +1,23 @@
+CREATE TABLE IF NOT EXISTS private_assets (
+  object_key TEXT PRIMARY KEY,
+  body BLOB NOT NULL,
+  content_type TEXT,
+  size_bytes INTEGER NOT NULL,
+  metadata_json TEXT,
+  updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
+);
+
+CREATE INDEX IF NOT EXISTS private_assets_updated_at_idx
+  ON private_assets(updated_at);
+
+-- D1 limits the size of one BLOB value. Larger private sources are therefore
+-- split into small ordered rows while private_assets keeps their metadata.
+CREATE TABLE IF NOT EXISTS private_asset_chunks (
+  object_key TEXT NOT NULL,
+  chunk_index INTEGER NOT NULL,
+  body BLOB NOT NULL,
+  PRIMARY KEY (object_key, chunk_index)
+);
+
+CREATE INDEX IF NOT EXISTS private_asset_chunks_object_key_idx
+  ON private_asset_chunks(object_key);
diff --git a/server/src/services/appearance-storage-service.ts b/server/src/services/appearance-storage-service.ts
new file mode 100644
index 0000000..31a1673
--- /dev/null
+++ b/server/src/services/appearance-storage-service.ts
@@ -0,0 +1,134 @@
+import { SourceObjectNotFoundError, type SourceObjectStorage } from "../storage/source-object-storage.js";
+import { AppError } from "../errors/app-error.js";
+
+export type StoredAppearancePreferences = {
+  glassOpacity: number;
+  glassBlur: number;
+  readerFont: "rounded" | "serif" | "sans";
+  readerScale: number;
+  readerLineHeight: number;
+};
+
+export type StoredAppearance = {
+  preferences?: StoredAppearancePreferences;
+  backgroundDataUrl?: string;
+  updatedAt?: string;
+};
+
+const APPEARANCE_OBJECT_KEY = "private/appearance/profile-v1.json";
+const MAX_BACKGROUND_DATA_URL_CHARS = 1_300_000;
+
+export class AppearanceStorageService {
+  constructor(
+    private readonly storage: SourceObjectStorage,
+    private readonly now: () => Date = () => new Date()
+  ) {}
+
+  async load(): Promise<StoredAppearance> {
+    try {
+      const object = await this.storage.getObject(APPEARANCE_OBJECT_KEY);
+      const raw = JSON.parse(new TextDecoder().decode(object.bytes)) as unknown;
+      return normalizeStoredAppearance(raw);
+    } catch (error) {
+      if (error instanceof SourceObjectNotFoundError) return {};
+      throw error;
+    }
+  }
+
+  async save(input: {
+    preferences?: unknown;
+    backgroundDataUrl?: unknown;
+    removeBackground?: boolean;
+  }): Promise<StoredAppearance> {
+    const current = await this.load();
+    const preferences =
+      input.preferences === undefined
+        ? current.preferences
+        : normalizeAppearancePreferences(input.preferences);
+    const backgroundDataUrl = input.removeBackground
+      ? undefined
+      : input.backgroundDataUrl === undefined
+        ? current.backgroundDataUrl
+        : normalizeBackgroundDataUrl(input.backgroundDataUrl);
+    const updatedAt = this.now().toISOString();
+    const next: StoredAppearance = {
+      ...(preferences ? { preferences } : {}),
+      ...(backgroundDataUrl ? { backgroundDataUrl } : {}),
+      updatedAt
+    };
+    await this.storage.putObject({
+      key: APPEARANCE_OBJECT_KEY,
+      bytes: new TextEncoder().encode(JSON.stringify(next)),
+      contentType: "application/json"
+    });
+    return next;
+  }
+
+  async clearBackground(): Promise<StoredAppearance> {
+    return this.save({ removeBackground: true });
+  }
+}
+
+function normalizeStoredAppearance(value: unknown): StoredAppearance {
+  if (!value || typeof value !== "object" || Array.isArray(value)) return {};
+  const record = value as Record<string, unknown>;
+  const preferences = normalizeAppearancePreferences(record.preferences, false);
+  const backgroundDataUrl = normalizeBackgroundDataUrl(record.backgroundDataUrl, false);
+  return {
+    ...(preferences ? { preferences } : {}),
+    ...(backgroundDataUrl ? { backgroundDataUrl } : {}),
+    ...(typeof record.updatedAt === "string" ? { updatedAt: record.updatedAt } : {})
+  };
+}
+
+function normalizeAppearancePreferences(
+  value: unknown,
+  strict = true
+): StoredAppearancePreferences | undefined {
+  if (!value || typeof value !== "object" || Array.isArray(value)) {
+    if (strict) throw new AppError("INVALID_OPERATION", "外观设置格式无效。");
+    return undefined;
+  }
+  const record = value as Record<string, unknown>;
+  const readerFont = record.readerFont;
+  if (
+    !isFiniteNumber(record.glassOpacity) ||
+    !isFiniteNumber(record.glassBlur) ||
+    !isFiniteNumber(record.readerScale) ||
+    !isFiniteNumber(record.readerLineHeight) ||
+    (readerFont !== "rounded" && readerFont !== "serif" && readerFont !== "sans")
+  ) {
+    if (strict) throw new AppError("INVALID_OPERATION", "外观设置格式无效。");
+    return undefined;
+  }
+  return {
+    glassOpacity: clamp(record.glassOpacity, 0.03, 0.24),
+    glassBlur: clamp(record.glassBlur, 8, 36),
+    readerFont,
+    readerScale: clamp(record.readerScale, 0.9, 1.3),
+    readerLineHeight: clamp(record.readerLineHeight, 1.55, 2.2)
+  };
+}
+
+function normalizeBackgroundDataUrl(value: unknown, strict = true): string | undefined {
+  if (value === undefined || value === null || value === "") return undefined;
+  if (
+    typeof value !== "string" ||
+    !/^data:image\/(?:jpeg|png|webp);base64,[A-Za-z0-9+/=]+$/.test(value) ||
+    value.length > MAX_BACKGROUND_DATA_URL_CHARS
+  ) {
+    if (strict) {
+      throw new AppError("INVALID_OPERATION", "背景图片格式无效或压缩后仍然太大。");
+    }
+    return undefined;
+  }
+  return value;
+}
+
+function isFiniteNumber(value: unknown): value is number {
+  return typeof value === "number" && Number.isFinite(value);
+}
+
+function clamp(value: number, min: number, max: number) {
+  return Math.min(max, Math.max(min, value));
+}
diff --git a/server/src/storage/d1-source-object-storage.test.ts b/server/src/storage/d1-source-object-storage.test.ts
new file mode 100644
index 0000000..661a019
--- /dev/null
+++ b/server/src/storage/d1-source-object-storage.test.ts
@@ -0,0 +1,141 @@
+import { describe, expect, it } from "vitest";
+import { Buffer } from "node:buffer";
+import {
+  D1SourceObjectStorage,
+  type D1AssetDatabaseLike
+} from "./d1-source-object-storage.js";
+
+describe("D1SourceObjectStorage", () => {
+  it("round-trips private binary objects without exposing a URL", async () => {
+    const database = new MemoryD1Assets();
+    const storage = new D1SourceObjectStorage(database);
+    const key = "private/sources/source-d1/source.txt";
+
+    await expect(
+      storage.putObject({
+        key,
+        bytes: new TextEncoder().encode("跨窗口正文"),
+        contentType: "text/plain;charset=utf-8",
+        metadata: { private: "true" }
+      })
+    ).resolves.toMatchObject({ key });
+    await expect(storage.headObject(key)).resolves.toMatchObject({
+      exists: true,
+      contentType: "text/plain;charset=utf-8"
+    });
+    const restored = await storage.getObject(key);
+    expect(new TextDecoder().decode(restored.bytes)).toBe("跨窗口正文");
+    expect(restored).not.toHaveProperty("publicUrl");
+    expect(restored).not.toHaveProperty("signedUrl");
+    await expect(storage.deleteObject(key)).resolves.toEqual({ deleted: true });
+    await expect(storage.getObject(key)).rejects.toThrow("Source object not found");
+  });
+
+  it("round-trips a 3.5 MiB private novel through ordered D1 chunks", async () => {
+    const database = new MemoryD1Assets();
+    const storage = new D1SourceObjectStorage(database);
+    const bytes = new Uint8Array(Math.floor(3.5 * 1024 * 1024));
+    for (let index = 0; index < bytes.length; index += 1) bytes[index] = index % 251;
+
+    await storage.putObject({ key: "large-novel", bytes });
+    const restored = new Uint8Array((await storage.getObject("large-novel")).bytes);
+
+    expect(restored.byteLength).toBe(bytes.byteLength);
+    expect(Buffer.compare(Buffer.from(restored), Buffer.from(bytes))).toBe(0);
+    expect(database.chunkCount("large-novel")).toBeGreaterThan(1);
+  });
+
+  it("rejects objects above the private source limit", async () => {
+    const storage = new D1SourceObjectStorage(new MemoryD1Assets());
+    await expect(
+      storage.putObject({ key: "too-large", bytes: new Uint8Array(5 * 1024 * 1024 + 1) })
+    ).rejects.toThrow("5 MiB 限制");
+  });
+});
+
+type Asset = {
+  body: ArrayBuffer;
+  content_type: string | null;
+  size_bytes: number;
+  metadata_json: string | null;
+};
+
+class MemoryD1Assets implements D1AssetDatabaseLike {
+  private readonly assets = new Map<string, Asset>();
+  private readonly chunks = new Map<string, Map<number, ArrayBuffer>>();
+
+  chunkCount(key: string): number {
+    return this.chunks.get(key)?.size ?? 0;
+  }
+
+  prepare(sql: string): FakeStatement {
+    return this.statement(sql, []);
+  }
+
+  private statement(sql: string, values: unknown[]): FakeStatement {
+    return {
+      bind: (...next: unknown[]) => this.statement(sql, next),
+      first: async <T>() => this.first<T>(sql, values),
+      all: async <T>() => this.all<T>(sql, values),
+      run: async () => this.run(sql, values)
+    };
+  }
+
+  private async all<T>(sql: string, values: unknown[]): Promise<{ success: boolean; results: T[] }> {
+    if (!sql.includes("FROM private_asset_chunks")) return { success: true, results: [] };
+    const chunks = this.chunks.get(String(values[0])) ?? new Map();
+    return {
+      success: true,
+      results: [...chunks.entries()]
+        .sort(([left], [right]) => left - right)
+        .map(([, body]) => ({ body: body.slice(0) } as T))
+    };
+  }
+
+  private async first<T>(sql: string, values: unknown[]): Promise<T | null> {
+    if (!sql.includes("FROM private_assets")) return null;
+    const asset = this.assets.get(String(values[0]));
+    if (!asset) return null;
+    if (sql.includes("SELECT content_type, size_bytes")) {
+      return { content_type: asset.content_type, size_bytes: asset.size_bytes } as T;
+    }
+    return { ...asset, body: asset.body.slice(0) } as T;
+  }
+
+  private async run(sql: string, values: unknown[]) {
+    if (sql.includes("INSERT INTO private_assets")) {
+      const [key, body, contentType, sizeBytes, metadataJson] = values;
+      const bytes = body as ArrayBuffer;
+      this.assets.set(String(key), {
+        body: bytes.slice(0),
+        content_type: typeof contentType === "string" ? contentType : null,
+        size_bytes: Number(sizeBytes),
+        metadata_json: typeof metadataJson === "string" ? metadataJson : null
+      });
+      return { success: true, meta: { changes: 1 } };
+    }
+    if (sql.includes("INSERT INTO private_asset_chunks")) {
+      const [key, index, body] = values;
+      const chunks = this.chunks.get(String(key)) ?? new Map<number, ArrayBuffer>();
+      chunks.set(Number(index), (body as ArrayBuffer).slice(0));
+      this.chunks.set(String(key), chunks);
+      return { success: true, meta: { changes: 1 } };
+    }
+    if (sql.includes("DELETE FROM private_asset_chunks")) {
+      const deleted = this.chunks.delete(String(values[0]));
+      return { success: true, meta: { changes: deleted ? 1 : 0 } };
+    }
+    if (sql.includes("DELETE FROM private_assets")) {
+      const deleted = this.assets.delete(String(values[0]));
+      return { success: true, meta: { changes: deleted ? 1 : 0 } };
+    }
+    return { success: true, meta: { changes: 0 } };
+  }
+}
+
+type FakeStatement = {
+  bind(...values: unknown[]): FakeStatement;
+  first<T>(): Promise<T | null>;
+  all<T>(): Promise<{ success: boolean; results: T[] }>;
+  run(): Promise<{ success: boolean; meta: { changes?: number } }>;
+};
diff --git a/server/src/storage/d1-source-object-storage.ts b/server/src/storage/d1-source-object-storage.ts
new file mode 100644
index 0000000..d242432
--- /dev/null
+++ b/server/src/storage/d1-source-object-storage.ts
@@ -0,0 +1,175 @@
+import {
+  SourceObjectNotFoundError,
+  sourceBytesToArrayBuffer,
+  type SourceObjectStorage
+} from "./source-object-storage.js";
+
+type D1ResultLike = {
+  success: boolean;
+  meta: { changes?: number };
+};
+
+type D1RowsLike<T> = {
+  success: boolean;
+  results: T[];
+};
+
+type D1StatementLike = {
+  bind(...values: unknown[]): D1StatementLike;
+  first<T>(): Promise<T | null>;
+  all<T>(): Promise<D1RowsLike<T>>;
+  run(): Promise<D1ResultLike>;
+};
+
+export interface D1AssetDatabaseLike {
+  prepare(sql: string): D1StatementLike;
+}
+
+type AssetRow = {
+  body: ArrayBuffer | Uint8Array;
+  content_type: string | null;
+  size_bytes: number;
+  metadata_json: string | null;
+};
+
+type AssetChunkRow = { body: ArrayBuffer | Uint8Array };
+
+const D1_PRIVATE_ASSET_CHUNK_BYTES = 512 * 1024;
+const MAX_D1_PRIVATE_ASSET_BYTES = 5 * 1024 * 1024;
+
+export class D1SourceObjectStorage implements SourceObjectStorage {
+  constructor(private readonly database: D1AssetDatabaseLike) {}
+
+  async putObject(input: {
+    key: string;
+    bytes: Uint8Array | ArrayBuffer | Blob;
+    contentType?: string;
+    metadata?: Record<string, string>;
+  }): Promise<{ key: string; sizeBytes: number }> {
+    const bytes = await sourceBytesToArrayBuffer(input.bytes);
+    if (bytes.byteLength > MAX_D1_PRIVATE_ASSET_BYTES) {
+      throw new Error("私人资源超过 5 MiB 限制，请缩小文件后重试。");
+    }
+    await this.database
+      .prepare("DELETE FROM private_asset_chunks WHERE object_key = ?")
+      .bind(input.key)
+      .run();
+
+    const usesChunks = bytes.byteLength > D1_PRIVATE_ASSET_CHUNK_BYTES;
+    await this.database
+      .prepare(
+        `INSERT INTO private_assets
+          (object_key, body, content_type, size_bytes, metadata_json, updated_at)
+         VALUES (?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
+         ON CONFLICT(object_key) DO UPDATE SET
+          body = excluded.body,
+          content_type = excluded.content_type,
+          size_bytes = excluded.size_bytes,
+          metadata_json = excluded.metadata_json,
+          updated_at = CURRENT_TIMESTAMP`
+      )
+      .bind(
+        input.key,
+        usesChunks ? new ArrayBuffer(0) : bytes,
+        input.contentType ?? null,
+        bytes.byteLength,
+        input.metadata ? JSON.stringify(input.metadata) : null
+      )
+      .run();
+
+    if (usesChunks) {
+      for (let offset = 0, index = 0; offset < bytes.byteLength; offset += D1_PRIVATE_ASSET_CHUNK_BYTES, index += 1) {
+        await this.database
+          .prepare(
+            `INSERT INTO private_asset_chunks (object_key, chunk_index, body)
+             VALUES (?, ?, ?)`
+          )
+          .bind(input.key, index, bytes.slice(offset, offset + D1_PRIVATE_ASSET_CHUNK_BYTES))
+          .run();
+      }
+    }
+    return { key: input.key, sizeBytes: bytes.byteLength };
+  }
+
+  async getObject(key: string): Promise<{
+    bytes: ArrayBuffer;
+    contentType?: string;
+    sizeBytes?: number;
+  }> {
+    const row = await this.database
+      .prepare(
+        "SELECT body, content_type, size_bytes, metadata_json FROM private_assets WHERE object_key = ?"
+      )
+      .bind(key)
+      .first<AssetRow>();
+    if (!row) throw new SourceObjectNotFoundError(key);
+    const inlineBytes = copyArrayBuffer(row.body);
+    let bytes = inlineBytes;
+    if (inlineBytes.byteLength !== row.size_bytes) {
+      const result = await this.database
+        .prepare(
+          "SELECT body FROM private_asset_chunks WHERE object_key = ? ORDER BY chunk_index ASC"
+        )
+        .bind(key)
+        .all<AssetChunkRow>();
+      bytes = joinChunks(result.results.map((chunk) => copyArrayBuffer(chunk.body)), row.size_bytes);
+    }
+    return {
+      bytes,
+      ...(row.content_type ? { contentType: row.content_type } : {}),
+      sizeBytes: row.size_bytes
+    };
+  }
+
+  async headObject(key: string): Promise<{
+    exists: boolean;
+    contentType?: string;
+    sizeBytes?: number;
+  }> {
+    const row = await this.database
+      .prepare(
+        "SELECT content_type, size_bytes FROM private_assets WHERE object_key = ?"
+      )
+      .bind(key)
+      .first<Pick<AssetRow, "content_type" | "size_bytes">>();
+    if (!row) return { exists: false };
+    return {
+      exists: true,
+      ...(row.content_type ? { contentType: row.content_type } : {}),
+      sizeBytes: row.size_bytes
+    };
+  }
+
+  async deleteObject(key: string): Promise<{ deleted: boolean }> {
+    await this.database
+      .prepare("DELETE FROM private_asset_chunks WHERE object_key = ?")
+      .bind(key)
+      .run();
+    const result = await this.database
+      .prepare("DELETE FROM private_assets WHERE object_key = ?")
+      .bind(key)
+      .run();
+    return { deleted: (result.meta.changes ?? 0) > 0 };
+  }
+}
+
+function joinChunks(chunks: ArrayBuffer[], expectedSize: number): ArrayBuffer {
+  const joined = new Uint8Array(expectedSize);
+  let offset = 0;
+  for (const chunk of chunks) {
+    const bytes = new Uint8Array(chunk);
+    joined.set(bytes, offset);
+    offset += bytes.byteLength;
+  }
+  if (offset !== expectedSize) {
+    throw new Error("D1 私人资源分片不完整，请重新上传原文件。");
+  }
+  return joined.buffer;
+}
+
+function copyArrayBuffer(value: ArrayBuffer | Uint8Array): ArrayBuffer {
+  if (value instanceof ArrayBuffer) return value.slice(0);
+  const copy = new Uint8Array(value.byteLength);
+  copy.set(value);
+  return copy.buffer;
+}
