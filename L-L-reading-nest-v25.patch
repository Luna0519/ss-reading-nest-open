+import type {
+  ReadingDiscussion,
+  ReadingDiscussionDetail,
+  ReadingDiscussionMessage,
+  ReadingDiscussionMessageRole,
+  ReadingDiscussionMood,
+  ReadingDiscussionSummary,
+  ReadingPosition
+} from "@ss/shared";
+
+export interface CreateReadingDiscussionInput {
+  sessionId: string;
+  position: ReadingPosition;
+  anchorCommentId: string;
+  anchorText: string;
+}
+
+export interface AppendReadingDiscussionMessageInput {
+  discussionId: string;
+  role: ReadingDiscussionMessageRole;
+  text: string;
+  operationId: string;
+}
+
+export interface ReadingDiscussionRepository {
+  getOrCreate(input: CreateReadingDiscussionInput): Promise<ReadingDiscussionDetail>;
+  get(discussionId: string): Promise<ReadingDiscussion | null>;
+  getDetail(discussionId: string): Promise<ReadingDiscussionDetail | null>;
+  setMood(
+    discussionId: string,
+    mood: ReadingDiscussionMood | null
+  ): Promise<ReadingDiscussion | null>;
+  appendMessage(
+    input: AppendReadingDiscussionMessageInput
+  ): Promise<ReadingDiscussionMessage | null>;
+  close(discussionId: string): Promise<ReadingDiscussion | null>;
+  listBySession(sessionId: string): Promise<ReadingDiscussionSummary[]>;
+  deleteBySession(sessionId: string): Promise<void>;
+}
diff --git a/server/src/services/appearance-storage-service.ts b/server/src/services/appearance-storage-service.ts
new file mode 100644
index 0000000..31a1673
--- /dev/null
+++ b/server/src/services/appearance-storage-service.ts
@@ -0,0 +1,134 @@
+import { SourceObjectNotFoundError, type SourceObjectStorage } from "../storage/source-object-storage.js";
+import { AppError } from "../errors/app-error.js";
+
+export type StoredAppearancePreferences = {
+  glassOpacity: number;
+  glassBlur: number;
+  readerFont: "rounded" | "serif" | "sans";
+  readerScale: number;
+  readerLineHeight: number;
+};
+
+export type StoredAppearance = {
+  preferences?: StoredAppearancePreferences;
+  backgroundDataUrl?: string;
+  updatedAt?: string;
+};
+
+const APPEARANCE_OBJECT_KEY = "private/appearance/profile-v1.json";
+const MAX_BACKGROUND_DATA_URL_CHARS = 1_300_000;
+
+export class AppearanceStorageService {
+  constructor(
+    private readonly storage: SourceObjectStorage,
+    private readonly now: () => Date = () => new Date()
+  ) {}
+
+  async load(): Promise<StoredAppearance> {
+    try {
+      const object = await this.storage.getObject(APPEARANCE_OBJECT_KEY);
+      const raw = JSON.parse(new TextDecoder().decode(object.bytes)) as unknown;
+      return normalizeStoredAppearance(raw);
+    } catch (error) {
+      if (error instanceof SourceObjectNotFoundError) return {};
+      throw error;
+    }
+  }
+
+  async save(input: {
+    preferences?: unknown;
+    backgroundDataUrl?: unknown;
+    removeBackground?: boolean;
+  }): Promise<StoredAppearance> {
+    const current = await this.load();
+    const preferences =
+      input.preferences === undefined
+        ? current.preferences
+        : normalizeAppearancePreferences(input.preferences);
+    const backgroundDataUrl = input.removeBackground
+      ? undefined
+      : input.backgroundDataUrl === undefined
+        ? current.backgroundDataUrl
+        : normalizeBackgroundDataUrl(input.backgroundDataUrl);
+    const updatedAt = this.now().toISOString();
+    const next: StoredAppearance = {
+      ...(preferences ? { preferences } : {}),
+      ...(backgroundDataUrl ? { backgroundDataUrl } : {}),
+      updatedAt
+    };
+    await this.storage.putObject({
+      key: APPEARANCE_OBJECT_KEY,
+      bytes: new TextEncoder().encode(JSON.stringify(next)),
+      contentType: "application/json"
+    });
+    return next;
+  }
+
+  async clearBackground(): Promise<StoredAppearance> {
+    return this.save({ removeBackground: true });
+  }
+}
+
+function normalizeStoredAppearance(value: unknown): StoredAppearance {
+  if (!value || typeof value !== "object" || Array.isArray(value)) return {};
+  const record = value as Record<string, unknown>;
+  const preferences = normalizeAppearancePreferences(record.preferences, false);
+  const backgroundDataUrl = normalizeBackgroundDataUrl(record.backgroundDataUrl, false);
+  return {
+    ...(preferences ? { preferences } : {}),
+    ...(backgroundDataUrl ? { backgroundDataUrl } : {}),
+    ...(typeof record.updatedAt === "string" ? { updatedAt: record.updatedAt } : {})
+  };
+}
+
+function normalizeAppearancePreferences(
+  value: unknown,
+  strict = true
+): StoredAppearancePreferences | undefined {
+  if (!value || typeof value !== "object" || Array.isArray(value)) {
+    if (strict) throw new AppError("INVALID_OPERATION", "外观设置格式无效。");
+    return undefined;
+  }
+  const record = value as Record<string, unknown>;
+  const readerFont = record.readerFont;
+  if (
+    !isFiniteNumber(record.glassOpacity) ||
+    !isFiniteNumber(record.glassBlur) ||
+    !isFiniteNumber(record.readerScale) ||
+    !isFiniteNumber(record.readerLineHeight) ||
+    (readerFont !== "rounded" && readerFont !== "serif" && readerFont !== "sans")
+  ) {
+    if (strict) throw new AppError("INVALID_OPERATION", "外观设置格式无效。");
+    return undefined;
+  }
+  return {
+    glassOpacity: clamp(record.glassOpacity, 0.03, 0.24),
+    glassBlur: clamp(record.glassBlur, 8, 36),
+    readerFont,
+    readerScale: clamp(record.readerScale, 0.9, 1.3),
+    readerLineHeight: clamp(record.readerLineHeight, 1.55, 2.2)
+  };
+}
+
+function normalizeBackgroundDataUrl(value: unknown, strict = true): string | undefined {
+  if (value === undefined || value === null || value === "") return undefined;
+  if (
+    typeof value !== "string" ||
+    !/^data:image\/(?:jpeg|png|webp);base64,[A-Za-z0-9+/=]+$/.test(value) ||
+    value.length > MAX_BACKGROUND_DATA_URL_CHARS
+  ) {
+    if (strict) {
+      throw new AppError("INVALID_OPERATION", "背景图片格式无效或压缩后仍然太大。");
+    }
+    return undefined;
+  }
+  return value;
+}
+
+function isFiniteNumber(value: unknown): value is number {
+  return typeof value === "number" && Number.isFinite(value);
+}
+
+function clamp(value: number, min: number, max: number) {
+  return Math.min(max, Math.max(min, value));
+}
