+import { describe, expect, it } from "vitest";
+import {
+  buildInlineWidgetHtml,
+  handleWidgetAsset,
+  LEGACY_WIDGET_SCRIPT_PATH,
+  LEGACY_WIDGET_STYLE_PATH,
+  PREVIOUS_WIDGET_SCRIPT_PATH,
+  PREVIOUS_WIDGET_STYLE_PATH,
+  WIDGET_SCRIPT_PATH,
+  WIDGET_STYLE_PATH
+} from "./widget-assets.js";
+
+const assets = {
+  script: "const price = '$&'; console.log('</script>', price);",
+  styles: ".app{display:block}/* </style> */"
+};
+
+describe("versioned widget assets", () => {
+  it("builds a self-contained HTML template for the ChatGPT iframe", () => {
+    const html = buildInlineWidgetHtml(
+      `<!doctype html><html><head><script type="module" crossorigin src="${WIDGET_SCRIPT_PATH}"></script><link rel="stylesheet" crossorigin href="${WIDGET_STYLE_PATH}"></head><body><div id="root"></div></body></html>`,
+      assets
+    );
+
+    expect(html).toContain(
+      '<style data-ll-widget-styles>.app{display:block}/* <\\/style> */</style>'
+    );
+    expect(html).toContain(
+      '<script type="module" data-ll-widget-script>const price = \'$&\'; console.log(\'<\\/script>\', price);</script>'
+    );
+    expect(html).not.toContain(`src="${WIDGET_SCRIPT_PATH}"`);
+    expect(html).not.toContain(`href="${WIDGET_STYLE_PATH}"`);
+  });
+
+  it("rejects an incomplete HTML shell instead of publishing a broken template", () => {
+    expect(() => buildInlineWidgetHtml("<div id=\"root\"></div>", assets)).toThrow(
+      /missing its versioned JavaScript or stylesheet/
+    );
+  });
+
+  it("serves JavaScript and CSS with immutable cross-origin headers", async () => {
+    const script = handleWidgetAsset(
+      new Request(`https://example.workers.dev${WIDGET_SCRIPT_PATH}`),
+      new URL(`https://example.workers.dev${WIDGET_SCRIPT_PATH}`),
+      assets
+    );
+    expect(script.status).toBe(200);
+    expect(script.headers.get("content-type")).toContain("text/javascript");
+    expect(script.headers.get("access-control-allow-origin")).toBe("*");
+    expect(script.headers.get("cache-control")).toContain("immutable");
+    expect(await script.text()).toBe(assets.script);
+
+    const styles = handleWidgetAsset(
+      new Request(`https://example.workers.dev${WIDGET_STYLE_PATH}`),
+      new URL(`https://example.workers.dev${WIDGET_STYLE_PATH}`),
+      assets
+    );
+    expect(styles.status).toBe(200);
+    expect(styles.headers.get("content-type")).toContain("text/css");
+    expect(await styles.text()).toBe(assets.styles);
+  });
+
+  it("keeps the cached v26 template asset URLs alive", async () => {
+    const script = handleWidgetAsset(
+      new Request(`https://example.workers.dev${LEGACY_WIDGET_SCRIPT_PATH}`),
+      new URL(`https://example.workers.dev${LEGACY_WIDGET_SCRIPT_PATH}`),
+      assets
+    );
+    const styles = handleWidgetAsset(
+      new Request(`https://example.workers.dev${LEGACY_WIDGET_STYLE_PATH}`),
+      new URL(`https://example.workers.dev${LEGACY_WIDGET_STYLE_PATH}`),
+      assets
+    );
+
+    expect(script.status).toBe(200);
+    expect(script.headers.get("content-type")).toContain("text/javascript");
+    expect(await script.text()).toBe(assets.script);
+    expect(styles.status).toBe(200);
+    expect(styles.headers.get("content-type")).toContain("text/css");
+    expect(await styles.text()).toBe(assets.styles);
+  });
+
+  it("keeps the immediately previous v0213 asset URLs alive", async () => {
+    const script = handleWidgetAsset(
+      new Request(`https://example.workers.dev${PREVIOUS_WIDGET_SCRIPT_PATH}`),
+      new URL(`https://example.workers.dev${PREVIOUS_WIDGET_SCRIPT_PATH}`),
+      assets
+    );
+    const styles = handleWidgetAsset(
+      new Request(`https://example.workers.dev${PREVIOUS_WIDGET_STYLE_PATH}`),
+      new URL(`https://example.workers.dev${PREVIOUS_WIDGET_STYLE_PATH}`),
+      assets
+    );
+
+    expect(script.status).toBe(200);
+    expect(await script.text()).toBe(assets.script);
+    expect(styles.status).toBe(200);
+    expect(await styles.text()).toBe(assets.styles);
+  });
+
+  it("supports HEAD and rejects mutation requests", async () => {
+    const head = handleWidgetAsset(
+      new Request(`https://example.workers.dev${WIDGET_SCRIPT_PATH}`, { method: "HEAD" }),
+      new URL(`https://example.workers.dev${WIDGET_SCRIPT_PATH}`),
+      assets
+    );
+    expect(await head.text()).toBe("");
+
+    const post = handleWidgetAsset(
+      new Request(`https://example.workers.dev${WIDGET_STYLE_PATH}`, { method: "POST" }),
+      new URL(`https://example.workers.dev${WIDGET_STYLE_PATH}`),
+      assets
+    );
+    expect(post.status).toBe(405);
+  });
+});
