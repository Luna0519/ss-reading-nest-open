+.book-source.mismatch,
+.book-source.segmentation_mismatch,
+.danger-zone,
+.companion-comment.live-comment {
+  border: 1px solid rgb(255 255 255 / .32);
+  background:
+    linear-gradient(145deg, rgb(255 255 255 / .26), transparent),
+    rgb(var(--glass-rgb) / var(--glass-opacity));
+  box-shadow: inset 0 1px 0 rgb(255 255 255 / .46);
+}
+
+.bookshelf-filters button[aria-pressed="true"],
+.choice-chip[aria-pressed="true"],
+.record-tabs button[aria-pressed="true"],
+.font-choice[aria-pressed="true"],
+.reader-actions .action-primary,
+.action-primary {
+  border-color: rgb(255 255 255 / .48);
+  background:
+    linear-gradient(145deg, rgb(255 255 255 / .22), transparent 48%),
+    linear-gradient(135deg, rgb(43 77 105 / .72), rgb(91 74 113 / .58));
+  color: #f8fbff;
+  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.45);
+  backdrop-filter: blur(var(--glass-blur)) saturate(1.45);
+  box-shadow:
+    inset 0 1px 0 rgb(255 255 255 / .38),
+    0 10px 24px rgb(25 49 68 / .16);
+  text-shadow: 0 1px 2px rgb(17 34 48 / .34);
+}
+
+.setup-shell {
+  border-radius: 34px;
+}
+
+.setup-shell::before {
+  background: rgb(255 239 199 / .24);
+  filter: blur(18px);
+}
+
+input,
+textarea,
+.setup-shell .source-import-button,
+.appearance-sheet .source-import-button {
+  background: var(--glass-control);
+  color: var(--ink);
+}
+
+input::placeholder,
+textarea::placeholder {
+  color: color-mix(in srgb, var(--muted) 84%, transparent);
+}
+
+.source-input,
+.file-drop {
+  -webkit-backdrop-filter: var(--glass-filter-strong);
+  backdrop-filter: var(--glass-filter-strong);
+}
+
+.file-drop {
+  border-style: dashed;
+  border-width: 1.5px;
+}
+
+.reader-shell {
+  background: transparent;
+}
+
+.reader-header,
+.sync-status,
+.reader-actions {
+  border-color: var(--glass-border-soft);
+  background: var(--glass-panel);
+  -webkit-backdrop-filter: var(--glass-filter-strong);
+  backdrop-filter: var(--glass-filter-strong);
+  box-shadow: var(--glass-shadow-soft);
+}
+
+.reader-header {
+  border-width: 0 0 1px;
+}
+
+.sync-status {
+  border-width: 0 0 1px;
+}
+
+.reader-actions {
+  border-width: 1px 0 0;
+  box-shadow:
+    inset 0 1px 0 rgb(255 255 255 / .55),
+    0 -14px 34px rgb(24 51 72 / .1);
+}
+
+.novel-scroll {
+  padding-top: 22px;
+}
+
+.novel-paper {
+  min-height: calc(54dvh - 4px);
+  border-radius: 30px;
+  background: var(--glass-reader);
+  -webkit-backdrop-filter: var(--glass-filter-strong);
+  backdrop-filter: var(--glass-filter-strong);
+  box-shadow:
+    inset 0 1.5px 0 rgb(255 255 255 / .72),
+    inset 1px 0 0 rgb(255 255 255 / .2),
+    inset 0 -1px 0 rgb(30 57 78 / .08),
+    0 20px 52px rgb(24 51 72 / .13);
+}
+
+.novel-paper p {
+  color: var(--ink);
+  text-shadow:
+    0 1px 0 rgb(255 255 255 / .5),
+    0 0 14px rgb(255 255 255 / .18);
+}
+
+.manga-page {
+  border: 1px solid var(--glass-border);
+  background: rgb(var(--glass-rgb) / .16);
+  box-shadow: var(--glass-shadow);
+}
+
+.companion-dock {
+  background: var(--glass-panel);
+  -webkit-backdrop-filter: var(--glass-filter-strong);
+  backdrop-filter: var(--glass-filter-strong);
+  box-shadow: var(--glass-shadow-soft);
+}
+
+.companion-dock-wide {
+  border-width: 0 0 0 1px;
+}
+
+.companion-dock-compact {
+  border-width: 1px 0 0;
+}
+
+.companion-dock-collapsed {
+  border: 0;
+  background: transparent;
+  -webkit-backdrop-filter: none;
+  backdrop-filter: none;
+  box-shadow: none;
+}
+
+.sheet-backdrop,
+.appearance-backdrop {
+  background: rgb(17 36 52 / .16);
+  -webkit-backdrop-filter: blur(9px) saturate(1.18);
+  backdrop-filter: blur(9px) saturate(1.18);
+}
+
+.bottom-sheet,
+.appearance-sheet {
+  border: 1px solid var(--glass-border);
+  border-bottom: 0;
+  background: var(--glass-panel);
+  -webkit-backdrop-filter: var(--glass-filter-strong);
+  backdrop-filter: var(--glass-filter-strong);
+  box-shadow:
+    inset 0 1.5px 0 rgb(255 255 255 / .74),
+    0 -22px 68px rgb(24 51 72 / .2);
+}
+
+.appearance-section,
+.comment-preferences,
+.management-section {
+  background: var(--glass-surface);
+  box-shadow: var(--glass-shadow-soft);
+}
+
+.background-preview,
+.background-placeholder {
+  border-color: var(--glass-border);
+  box-shadow: var(--glass-shadow-soft);
+}
+
+.background-placeholder {
+  background:
+    radial-gradient(circle at 74% 18%, rgb(255 244 207 / .46), transparent 25%),
+    linear-gradient(135deg, rgb(150 186 213 / .38), rgb(215 190 211 / .3)),
+    var(--glass-panel);
+}
+
+.appearance-footer {
+  background: linear-gradient(transparent, rgb(var(--glass-rgb) / .38) 36%);
+  -webkit-backdrop-filter: blur(var(--glass-blur));
+  backdrop-filter: blur(var(--glass-blur));
+}
+
+.appearance-range input[type="range"] {
+  border: 1px solid rgb(255 255 255 / .4);
+  background: linear-gradient(90deg, rgb(83 128 159 / .8), rgb(145 112 143 / .72));
+  box-shadow:
+    inset 0 1px 2px rgb(33 61 82 / .12),
+    0 1px 0 rgb(255 255 255 / .45);
+  accent-color: var(--wood);
+}
+
+.toast {
+  border: 1px solid rgb(255 255 255 / .38);
+  background:
+    linear-gradient(145deg, rgb(255 255 255 / .18), transparent),
+    rgb(26 48 65 / .76);
+  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.35);
+  backdrop-filter: blur(var(--glass-blur)) saturate(1.35);
+  color: #f8fbff;
+  box-shadow: var(--glass-shadow);
+  text-shadow: 0 1px 2px rgb(13 26 36 / .4);
+}
+
+:root[data-ll-custom-background="true"] .app::before {
+  background:
+    linear-gradient(180deg, rgb(255 255 255 / .035), rgb(17 37 54 / .055)),
+    radial-gradient(circle at 18% 15%, rgb(255 255 255 / .5) 0 1.5px, transparent 2.5px),
+    radial-gradient(circle at 81% 10%, rgb(255 255 255 / .44) 0 1px, transparent 2px);
+}
+
+@supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
+  .home-hero,
+  .mode-card,
+  .book-card,
+  .setup-heading,
+  .novel-paper,
+  .reader-header,
+  .reader-actions,
+  .bottom-sheet {
+    background-color: rgb(239 247 253 / .84);
+  }
+}
+
 @media (min-width: 700px) {
   .home-shell { padding-inline: 40px; }
   .mode-grid { grid-template-columns: 1fr 1fr; }
