diff --git a/server/src/widget-assets.ts b/server/src/widget-assets.ts
new file mode 100644
index 0000000..dd3b2e4
--- /dev/null
+++ b/server/src/widget-assets.ts
@@ -0,0 +1,91 @@
+export const WIDGET_ASSET_BASE_PATH = "/widget-assets/v0213";
+export const WIDGET_SCRIPT_PATH = `${WIDGET_ASSET_BASE_PATH}/ll-reading-nest-v0213.bundle.js`;
+export const WIDGET_STYLE_PATH = `${WIDGET_ASSET_BASE_PATH}/ll-reading-nest-v0213.css`;
+export const LEGACY_WIDGET_SCRIPT_PATH =
+  "/widget-assets/v26/ll-reading-nest-v26.bundle.js";
+export const LEGACY_WIDGET_STYLE_PATH = "/widget-assets/v26/ll-reading-nest-v26.css";
+
+export type WidgetAssetBundle = {
+  script: string;
+  styles: string;
+};
+
+export function isWidgetAssetPath(pathname: string): boolean {
+  return (
+    pathname === WIDGET_SCRIPT_PATH ||
+    pathname === WIDGET_STYLE_PATH ||
+    pathname === LEGACY_WIDGET_SCRIPT_PATH ||
+    pathname === LEGACY_WIDGET_STYLE_PATH
+  );
+}
+
+export function buildInlineWidgetHtml(widgetHtml: string, assets: WidgetAssetBundle): string {
+  const stylesheetPattern = new RegExp(
+    `<link\\b[^>]*href=["'][^"']*${escapeRegExp(WIDGET_STYLE_PATH)}["'][^>]*>`,
+    "i"
+  );
+  const scriptPattern = new RegExp(
+    `<script\\b[^>]*src=["'][^"']*${escapeRegExp(WIDGET_SCRIPT_PATH)}["'][^>]*><\\/script>`,
+    "i"
+  );
+  if (!stylesheetPattern.test(widgetHtml) || !scriptPattern.test(widgetHtml)) {
+    throw new Error("Widget HTML is missing its versioned JavaScript or stylesheet entry");
+  }
+  return widgetHtml
+    .replace(
+      stylesheetPattern,
+      () => `<style data-ll-widget-styles>${escapeInlineStyle(assets.styles)}</style>`
+    )
+    .replace(
+      scriptPattern,
+      () => `<script type="module" data-ll-widget-script>${escapeInlineScript(assets.script)}</script>`
+    );
+}
+
+export function handleWidgetAsset(
+  request: Request,
+  url: URL,
+  assets: WidgetAssetBundle
+): Response {
+  if (request.method !== "GET" && request.method !== "HEAD") {
+    return new Response("Method not allowed", {
+      status: 405,
+      headers: { Allow: "GET, HEAD" }
+    });
+  }
+
+  if (
+    url.pathname === WIDGET_SCRIPT_PATH ||
+    url.pathname === LEGACY_WIDGET_SCRIPT_PATH
+  ) {
+    return assetResponse(request, assets.script, "text/javascript; charset=utf-8");
+  }
+  if (url.pathname === WIDGET_STYLE_PATH || url.pathname === LEGACY_WIDGET_STYLE_PATH) {
+    return assetResponse(request, assets.styles, "text/css; charset=utf-8");
+  }
+  return new Response("Not found", { status: 404 });
+}
+
+function assetResponse(request: Request, body: string, contentType: string): Response {
+  return new Response(request.method === "HEAD" ? null : body, {
+    headers: {
+      "Content-Type": contentType,
+      "Cache-Control": "public, max-age=31536000, immutable",
+      "Access-Control-Allow-Origin": "*",
+      "Cross-Origin-Resource-Policy": "cross-origin",
+      "X-Content-Type-Options": "nosniff"
+    }
+  });
+}
+
+function escapeRegExp(value: string): string {
+  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
+}
+
+function escapeInlineScript(value: string): string {
+  return value.replace(/<\/script/gi, "<\\/script");
+}
+
+function escapeInlineStyle(value: string): string {
+  return value.replace(/<\/style/gi, "<\\/style");
+}
