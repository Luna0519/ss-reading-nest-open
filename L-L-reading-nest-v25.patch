+import { Client } from "@modelcontextprotocol/sdk/client/index.js";
+import { InMemoryTransport } from "@modelcontextprotocol/sdk/inMemory.js";
+import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
+import { describe, expect, it } from "vitest";
+import {
+  buildInlineWidgetHtml,
+  WIDGET_SCRIPT_PATH,
+  WIDGET_STYLE_PATH
+} from "../widget-assets.js";
+import { registerReadingResource } from "./register-resource.js";
+import { READING_NEST_URI, registerReadingTools } from "./register-tools.js";
+
+describe("ChatGPT UI template MCP chain", () => {
+  it("keeps the tool, listed resource, and readable HTML on one exact URI", async () => {
+    const server = new McpServer({ name: "L&L UI integration test", version: "0.2.12" });
+    const widgetHtml = buildInlineWidgetHtml(
+      `<!doctype html><html><head><link rel="stylesheet" href="${WIDGET_STYLE_PATH}"></head><body><div id="root"></div><script type="module" src="${WIDGET_SCRIPT_PATH}"></script></body></html>`,
+      {
+        script: "document.querySelector('#root')?.setAttribute('data-ready', 'true');",
+        styles: "#root{display:block}"
+      }
+    );
+    registerReadingResource(server, widgetHtml, "https://reading-nest.example.workers.dev");
+    registerReadingTools(server, {} as never);
+
+    const client = new Client({ name: "L&L UI integration client", version: "0.2.12" });
+    const [clientTransport, serverTransport] = InMemoryTransport.createLinkedPair();
+
+    try {
+      await server.connect(serverTransport);
+      await client.connect(clientTransport);
+
+      const tools = await client.listTools();
+      const openTool = tools.tools.find((tool) => tool.name === "open_reading_nest");
+      expect(openTool?._meta?.ui).toEqual({ resourceUri: READING_NEST_URI });
+      expect(openTool?._meta?.["ui/resourceUri"]).toBe(READING_NEST_URI);
+      expect(openTool?._meta?.["openai/outputTemplate"]).toBe(READING_NEST_URI);
+
+      const resources = await client.listResources();
+      expect(resources.resources.some((resource) => resource.uri === READING_NEST_URI)).toBe(true);
+
+      const result = await client.readResource({ uri: READING_NEST_URI });
+      const template = result.contents.find((content) => content.uri === READING_NEST_URI);
+      expect(template?.uri).toBe(READING_NEST_URI);
+      expect(template?.mimeType).toBe("text/html;profile=mcp-app");
+      expect("text" in (template ?? {}) ? template?.text : undefined).toBe(widgetHtml);
+      expect("text" in (template ?? {}) ? template?.text : "").toMatch(/^<!doctype html>/i);
+      expect("text" in (template ?? {}) ? template?.text : "").toContain(
+        "data-ll-widget-script"
+      );
+      expect("text" in (template ?? {}) ? template?.text : "").not.toMatch(
+        /<(?:script|link)\b[^>]*(?:src|href)=/i
+      );
+    } finally {
+      await client.close();
+      await server.close();
+    }
+  });
+});
